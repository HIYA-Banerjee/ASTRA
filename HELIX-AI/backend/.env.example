# ── App ──
APP_NAME=HELIX AI
ENVIRONMENT=development
DEBUG=true

# ── Server ──
HOST=0.0.0.0
PORT=8000

# ── CORS ──
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

